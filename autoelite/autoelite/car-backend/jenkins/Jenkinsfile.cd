// ─────────────────────────────────────────────
//  car-backend — CD Pipeline (UPDATED)
// ─────────────────────────────────────────────

pipeline {

    agent any

    parameters {
        string(
            name        : 'IMAGE_URI',
            defaultValue: '',
            description : 'ECR image URI passed from CI pipeline'
        )
    }

    environment {
        AWS_REGION  = 'ap-south-1'
        EKS_CLUSTER = 'autoelite-cluster'
        NAMESPACE   = 'autoelite'
        IMAGE_URI   = "${params.IMAGE_URI}"
    }

    options {
        timestamps()
        timeout(time: 15, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        stage('Validate Input') {
            steps {
                script {
                    if (!IMAGE_URI?.trim()) {
                        error "❌ IMAGE_URI is empty. Aborting deployment."
                    }
                }
                echo "✅ Using image: ${IMAGE_URI}"
            }
        }

        stage('Stage 1 | Deploy to EKS') {
            steps {
                withCredentials([[
                    $class       : 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-credentials'
                ]]) {
                    sh '''
                        set -e

                        echo "🚀 Connecting to EKS cluster..."
                        aws eks update-kubeconfig \
                            --name ${EKS_CLUSTER} \
                            --region ${AWS_REGION}

                        echo "📦 Updating deployment image..."
                        kubectl set image deployment/car-backend \
                            car-backend=${IMAGE_URI} \
                            -n ${NAMESPACE}

                        echo "⏳ Waiting for rollout..."
                        kubectl rollout status deployment/car-backend \
                            -n ${NAMESPACE} \
                            --timeout=180s

                        echo "📊 Current pods:"
                        kubectl get pods -n ${NAMESPACE} -l app=car-backend

                        echo "✅ Deployment successful"
                    '''
                }
            }
        }

    }

    post {

        success {
            echo "✅ CD complete — ${IMAGE_URI} is live"
        }

        failure {
            echo "❌ Deployment failed — attempting rollback..."

            withCredentials([[
                $class       : 'AmazonWebServicesCredentialsBinding',
                credentialsId: 'aws-credentials'
            ]]) {
                sh '''
                    aws eks update-kubeconfig \
                        --name ${EKS_CLUSTER} \
                        --region ${AWS_REGION} || true

                    kubectl rollout undo deployment/car-backend \
                        -n ${NAMESPACE} || true

                    echo "🔁 Rollback executed"
                    kubectl rollout status deployment/car-backend \
                        -n ${NAMESPACE} || true
                '''
            }
        }

        always {
            cleanWs()
        }
    }
}